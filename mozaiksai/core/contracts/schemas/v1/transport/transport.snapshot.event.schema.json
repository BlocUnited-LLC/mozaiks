{
  "$id": "https://schemas.mozaiks.dev/contracts/events/v1/transport.snapshot.event.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "x-protocol-version": "1.0.0",
  "title": "TransportSnapshotEventV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_type",
    "seq",
    "occurred_at",
    "payload",
    "schema_version",
    "correlation_id",
    "process_id",
    "causation_id"
  ],
  "properties": {
    "event_type": {
      "type": "string",
      "const": "transport.snapshot"
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cursor",
        "stream_id",
        "run_id",
        "snapshot_id",
        "snapshot_uri"
      ],
      "properties": {
        "cursor": {
          "type": "integer",
          "minimum": 0
        },
        "stream_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_id": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_uri": {
          "type": "string",
          "minLength": 1
        },
        "state_hash": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "process_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    }
  }
}
