{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Payload describing a state snapshot reference.",
  "properties": {
    "codec": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Codec"
    },
    "metadata": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Metadata"
    },
    "snapshot_id": {
      "minLength": 1,
      "title": "Snapshot Id",
      "type": "string"
    },
    "snapshot_seq": {
      "minimum": 0,
      "title": "Snapshot Seq",
      "type": "integer"
    },
    "state_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "State Hash"
    },
    "state_ref": {
      "minLength": 1,
      "title": "State Ref",
      "type": "string"
    }
  },
  "required": [
    "snapshot_id",
    "snapshot_seq",
    "state_ref"
  ],
  "title": "SnapshotEventPayload",
  "type": "object",
  "x-kernel-contract": "mozaiks-runtime",
  "x-protocol-version": "1.0.0"
}
