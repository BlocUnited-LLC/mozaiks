# ============================================================
#  MozaiksAI Runtime — Environment Configuration
#  Copy this file to .env and fill in your values.
#  .env is gitignored — never commit real secrets.
# ============================================================


# ------------------------------------------------------------
# REQUIRED
# ------------------------------------------------------------

# Your OpenAI API key (used by AG2 agents for LLM calls).
OPENAI_API_KEY=sk-...

# MongoDB connection string.
# Local Docker:  mongodb://localhost:27017
# Atlas:         mongodb+srv://user:pass@cluster.mongodb.net
MONGO_URI=mongodb://localhost:27017


# ------------------------------------------------------------
# CORE
# ------------------------------------------------------------

# Runtime environment. Controls logging verbosity and CORS defaults.
# Values: development | production
ENVIRONMENT=development

# MongoDB database name (default: MozaiksAI).
MONGO_DB_NAME=MozaiksAI


# ------------------------------------------------------------
# AUTH (Keycloak — native identity provider)
# ------------------------------------------------------------
#
# Mozaiks ships with Keycloak as the default identity provider.
# Most settings are auto-loaded from app/brand/public/auth.json.
# Environment variables below OVERRIDE auth.json when set.
#
# For local development, set AUTH_ENABLED=false to bypass auth.
# For production, ensure Keycloak is running and AUTH_ENABLED=true.

AUTH_ENABLED=false

# --- Keycloak Server (docker-compose) ---

# Keycloak admin console credentials.
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin

# Keycloak Postgres password.
KC_DB_PASSWORD=keycloak

# Keycloak hostname (production: your auth domain, e.g. auth.myapp.com).
KC_HOSTNAME=localhost

# --- Keycloak / OIDC ---

# OIDC authority URL (default: http://localhost:8080/realms/mozaiks).
# For Keycloak this is: http(s)://<host>:<port>/realms/<realm>
MOZAIKS_OIDC_AUTHORITY=http://localhost:8080/realms/mozaiks

# Tenant ID — leave blank for Keycloak (only used for Azure AD/B2C).
MOZAIKS_OIDC_TENANT_ID=

# Explicit OIDC discovery URL (optional — auto-derived from authority).
MOZAIKS_OIDC_DISCOVERY_URL=

# Explicit issuer / JWKS overrides (optional — skip if using OIDC discovery).
AUTH_ISSUER=
AUTH_JWKS_URL=

# JWT audience (default: mozaiks-app — matches Keycloak client ID).
AUTH_AUDIENCE=mozaiks-app

# Required scope (default: openid).
AUTH_REQUIRED_SCOPE=openid

# JWT signing algorithms (default: RS256).
AUTH_ALGORITHMS=RS256

# Claim mappings (Keycloak defaults).
AUTH_USER_ID_CLAIM=sub
AUTH_EMAIL_CLAIM=email
AUTH_ROLES_CLAIM=realm_access

# Cache TTLs.
AUTH_JWKS_CACHE_TTL=3600
AUTH_DISCOVERY_CACHE_TTL=86400
AUTH_CLOCK_SKEW=120

# Path to auth.json (optional — default: auto-discovered in brand/public/).
# MOZAIKS_AUTH_JSON_PATH=


# ------------------------------------------------------------
# CORS / NETWORK
# ------------------------------------------------------------

# Frontend origin allowed in CORS during development.
# Only needed if running frontend on a non-default port.
# Default: http://localhost:3000
REACT_DEV_ORIGIN=http://localhost:3000


# ------------------------------------------------------------
# OPENAI / LLM
# ------------------------------------------------------------

# Comma-separated fallback model names if the primary model is unavailable.
# Example: gpt-4o-mini,gpt-3.5-turbo
OPENAI_MODEL_FALLBACK=

# LLM config cache TTL in seconds (default: 300).
LLM_CONFIG_CACHE_TTL=300


# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------

# Custom directory for log files (default: logs/logs/ inside repo).
LOGS_BASE_DIR=

# Set to true to emit logs as JSON (useful for log aggregators).
LOGS_AS_JSON=false

# Truncate long log messages at this character limit (leave blank for no limit).
LOG_MESSAGE_TRUNCATE_LIMIT=

# Set to 1 to delete existing *.log files on server startup.
CLEAR_LOGS_ON_START=0


# ------------------------------------------------------------
# RUNTIME — OPTIONAL TUNING
# ------------------------------------------------------------

# Comma-separated workflow names that allow file attachments.
CHAT_ATTACHMENTS_ALLOWED_WORKFLOWS=

# Idempotency window for duplicate chat-start requests in seconds (default: 15).
CHAT_START_IDEMPOTENCY_SEC=15

# Enforce x-mozaiks-app-id / x-mozaiks-user-id principal headers (default: false).
ENFORCE_PRINCIPAL_HEADERS=false

# Platform extension modules (managed — leave blank for open-source installs).
RUNTIME_PLATFORM_EXTENSIONS=
