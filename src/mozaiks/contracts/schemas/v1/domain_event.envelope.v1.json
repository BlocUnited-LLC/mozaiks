{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Canonical runtime event envelope.",
  "properties": {
    "event_type": {
      "minLength": 1,
      "title": "Event Type",
      "type": "string"
    },
    "metadata": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Metadata"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "payload": {
      "additionalProperties": true,
      "title": "Payload",
      "type": "object"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "minLength": 1,
      "title": "Schema Version",
      "type": "string"
    },
    "seq": {
      "minimum": 0,
      "title": "Seq",
      "type": "integer"
    }
  },
  "required": [
    "event_type",
    "seq",
    "occurred_at",
    "run_id",
    "schema_version",
    "payload"
  ],
  "title": "DomainEvent",
  "type": "object",
  "x-kernel-contract": "mozaiks-runtime",
  "x-protocol-version": "1.0.0"
}
