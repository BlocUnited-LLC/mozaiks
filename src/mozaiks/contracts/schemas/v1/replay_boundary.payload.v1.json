{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Payload for replay boundary marker events.",
  "properties": {
    "last_seq": {
      "minimum": 0,
      "title": "Last Seq",
      "type": "integer"
    },
    "replay_complete": {
      "default": true,
      "title": "Replay Complete",
      "type": "boolean"
    },
    "requested_last_seq": {
      "minimum": 0,
      "title": "Requested Last Seq",
      "type": "integer"
    }
  },
  "required": [
    "last_seq",
    "requested_last_seq"
  ],
  "title": "ReplayBoundaryPayload",
  "type": "object",
  "x-kernel-contract": "mozaiks-runtime",
  "x-protocol-version": "1.0.0"
}
